# Node
node_modules
node_modules/
# package-lock.json is intentionally committed.
# npm ci (used in the Dockerfile) requires the lockfile to guarantee
# reproducible installs in Docker builds and CI.  Excluding it causes
# every Docker build in CI to fail at COPY package-lock.json.

# Compiled frontend bundles — generated at Docker build time, never committed
agentception/static/app.js
agentception/static/app.css

# Agent ephemeral briefing files — never committed
# Runtime role-version ledger — written by the app server on every role commit.
# These are runtime state, not source code. Tracking them causes dev to appear
# dirty after every agent run. The DB is the canonical state store; these files
# are local caches for the running container / active worktree.
.agentception/role-versions.json
.agentception/memory.json
