# agentception/app.py                → {{ active_test_dir }}/test_agentception_scaffold.py
# agentception/readers/worktrees.py  → {{ active_test_dir }}/test_agentception_worktrees.py
# agentception/readers/github.py     → {{ active_test_dir }}/test_agentception_github.py
# agentception/poller.py             → {{ active_test_dir }}/test_agentception_poller.py
