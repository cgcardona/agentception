{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true
  },
  "include": [
    "agentception/static/js/**/*.ts",
    "agentception/static/js/**/*.js"
  ]
}
